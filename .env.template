# Copy this file to `.env` and fill in your OWN values. NEVER commit `.env`.
#
# These are session cookies from YOUR OWN logged-in browser sessions. They are
# optional — the pipeline degrades gracefully without them (public data still works),
# but some fields are login-gated. Use only your own accounts, for personal analysis,
# and respect each site's Terms of Use (see DISCLAIMER.md).

# screener.in — after logging in, copy the `sessionid` cookie value from browser devtools.
# Without it: financial statements still scrape, but About / Pros / Cons / some custom
# ratios are empty.
SCREENER_SESSION_ID=

# tijorifinance.com — the `sessionid` cookie from your logged-in session.
# Without it: Tijori-sourced tools (forensic checks, business profile, capital allocation,
# supply chain) are skipped with an explanatory message.
TIJORI_SESSION_ID=

# Optional: override the model the agent uses (defaults to your Claude Code default).
# FINANCE_AGENT_MODEL=claude-opus-4-8

# Optional: only if you run the agent via API key instead of a Claude subscription.
# ANTHROPIC_API_KEY=
